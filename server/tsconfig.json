{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "declaration": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "paths": {
      "@isekai/shared": ["../shared/dist/index.js"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
